{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MasterProfileSchema",
  "type": "OBJECT",
  "properties": {
    "personal": {
      "type": "OBJECT",
      "properties": {
        "first_name": { "type": "STRING" },
        "last_name": { "type": "STRING" },
        "email": { "type": "STRING", "format": "email" },
        "phone": { "type": "STRING", "pattern": "^[0-9]{10}$" },
        "website": { "type": "STRING", "format": "uri" },
        "linkedin": { "type": "STRING", "format": "uri" },
        "github": { "type": "STRING", "format": "uri" }
      },
      "required": ["first_name", "last_name", "email", "phone", "linkedin"]
    },
    "legal": {
      "type": "OBJECT",
      "properties": {
        "work_authorization_us": { "type": "STRING", "enum": ["yes", "no"] },
        "requires_sponsorship_future": { "type": "STRING", "enum": ["yes", "no"] },
        "requires_sponsorship_current": { "type": "STRING", "enum": ["yes", "no"] },
        "visa_type_current": { "type": "STRING", "enum": ["F1", "H1B", "US_Citizen", "Permanent_Resident", "None"] }
      },
      "required": ["work_authorization_us", "requires_sponsorship_future", "requires_sponsorship_current", "visa_type_current"]
    },
    "metadata": {
      "type": "OBJECT",
      "properties": {
        "expected_graduation": { "type": "STRING" },
        "degree": { "type": "STRING" },
        "majors": { "type": "ARRAY", "items": { "type": "STRING" } },
        "minor": { "type": "STRING" },
        "cumulative_gpa": { "type": "STRING" }
      },
      "required": ["expected_graduation", "degree", "majors"]
    }
  },
  "required": ["personal", "legal", "metadata"]
}
