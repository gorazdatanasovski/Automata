# System Execution Configuration
EXECUTION_MODE=stealth          # options: stealth, headful, debug
HEADLESS=true                  # options: true, false
BROWSER_TIMEOUT_MS=30000
GLOBAL_DELAY_MIN_MS=1000
GLOBAL_DELAY_MAX_MS=3000

# Proxy & Network Isolation
USE_PROXY=false
PROXY_SERVER=http://your-residential-proxy.com:8000
PROXY_USERNAME=unspecified
PROXY_PASSWORD=unspecified

# Data Asset Paths
PROFILE_DATA_PATH=./data/profile.json
RESUME_FILE_PATH=./data/resume.pdf
COVER_LETTER_PATH=./data/cover_letter.pdf

# Human-In-The-Loop Remediations
MANUAL_CAPTCHA_TIMEOUT_MS=120000  # Time allowed for terminal manual intervention
SCREENSHOT_ON_FAIL=true
DEBUG_DOM_DUMP=true
